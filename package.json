{
  "name": "mvp-web-ganaderia",
  "version": "1.0.0",
  "description": "MVP Web - Simuladores Productivos y EconÃ³micos para GanaderÃ­a",
  "main": "server/index.js",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "export:breed-reference-seed": "node server/scripts/export-breed-reference-seed.js",
    "parse:m4-master": "node server/scripts/parse-m4-master-csv.js",
    "reconcile:m4": "node server/scripts/reconcile-m4-csv.js",
    "seed:m4": "node server/scripts/seed-m4-breeds.js",
    "build:m4-seed-sql": "node server/scripts/build-m4-seed-sql.js",
    "build": "cd client && npm run build",
    "vercel-build": "npm install && cd server && npm install && cd ../client && npm install --include=dev && npm run build"
  },
  "keywords": [
    "simulator",
    "livestock",
    "dairy"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}

